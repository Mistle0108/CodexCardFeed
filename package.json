{
  "name": "codex-card-feed",
  "version": "0.1.0",
  "private": true,
  "description": "Electron app for browsing and organizing Codex threads as cards.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.js\"",
    "build": "vite build",
    "dist:win": "npm run build && electron-builder --win portable",
    "preview": "vite preview",
    "test": "node --test tests/electron/importer.test.js tests/electron/db.test.js tests/electron/background-tasks.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.2.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.mistle0108.codexcardfeed",
    "productName": "CodexCardFeed",
    "asar": false,
    "directories": {
      "output": "release-portable"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
